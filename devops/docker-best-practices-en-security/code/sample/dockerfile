# =============================================
# STAGE 1: Builder
# =============================================
FROM node:22.11-alpine3.21 AS builder

# Set working directory
WORKDIR /app

# Install build dependencies
RUN apk --no-cache add python3 make g++

# Copy package files first for better caching
COPY package*.json ./
COPY tsconfig*.json ./

# Install ALL dependencies (including devDependencies)
RUN npm ci --ignore-scripts

# Copy source code
COPY . .

# Build the NestJS app
RUN npm run build

# =============================================
# STAGE 2: Production Runtime (Minimal & Hardened)
# =============================================
FROM node:22.11-alpine3.21 AS runtime

# Create non-root user
RUN addgroup -g 1001 -S nodejs && \
    adduser -u 1001 -S -G nodejs nestjs

# Set working directory
WORKDIR /app

# Install only production runtime dependencies
COPY package*.json ./
RUN npm ci --only=production --ignore-scripts && \
    npm cache clean --force

# Copy compiled output from builder stage
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules ./node_modules

# Copy necessary config files (if any)
COPY --from=builder /app/package*.json ./

# Set proper ownership
RUN chown -R nestjs:nodejs /app && \
    chmod -R 550 /app

# Switch to non-root user
USER 1001

# Expose port (NestJS default is 3000)
EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:3000/health || exit 1

# Security & metadata labels
LABEL org.opencontainers.image.title="NestJS Secure App" \
      org.opencontainers.image.description="Production-ready NestJS application" \
      org.opencontainers.image.version="1.0.0" \
      org.opencontainers.image.authors="Your Team" \
      org.opencontainers.image.source="https://github.com/yourorg/your-nestjs-app"

# Run the application
CMD ["node", "dist/main.js"]